{
  "expo": {
    "name": "RuneoDriver",
    "slug": "runeodriver",
    "version": "2026.2.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "owner": "etml-inf-dev",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.mosiby.runeodriver",
      "buildNumber": "2026.2.2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "extraCMakeArguments": ["-DANDROID_SUPPORT_FLEXIBLE_PAGE_SIZES=ON"]
          }
        }
      ],
      "./plugins/withAndroidxCoreFix",
      "./plugins/withAndroidGoogleServices",
      "expo-font"
    ],
    "android": {
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE", "RECEIVE_BOOT_COMPLETED", "VIBRATE"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "ch.mosiby.runeodriver",
      "versionCode": 202622
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "d5569d2f-0ca9-4d7b-a8bf-7e4ff4f1319e"
      }
    }
  }
}
